# Set these in Vercel: Project → Settings → Environment Variables.
# For local: copy to .env and run `npm run dev` (server at http://localhost:3001).

# Optional: port for local server (default 3001)
# PORT=3001

# OpenAI (Whisper + GPT quote extraction)
OPENAI_API_KEY=sk-your-openai-api-key

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/voice_quote_db?schema=public"

# JWT (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS: comma-separated allowed origins (empty = allow all; used in production only)
# CORS_ALLOWLIST=https://my-frontend.vercel.app,http://localhost:5173

# Public base URL (used for WhatsApp media links — must be https)
PUBLIC_URL=https://awodo24.com

# File uploads (optional, defaults to ./uploads)
# ATTACHMENTS_DIR=/var/www/awodo/uploads

# SMTP email (for sending quotes via email)
# Fill these with your provider's settings (e.g. Gmail, Outlook, Mailgun, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Your Company <no-reply@example.com>"

# Twilio WhatsApp (optional, only needed if you use WhatsApp sending)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_FROM=+380975675655
