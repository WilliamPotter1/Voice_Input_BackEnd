// Voice-Based Quote Generator - Prisma Schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  phone          String?
  taxRate        Float?   @map("tax_rate")
  websiteUrl     String?  @map("website_url")
  companyName    String?  @map("company_name")
  companyAddress String?  @map("company_address")
  companyCity    String?  @map("company_city")
  bankName       String?  @map("bank_name")
  blz            String?
  kto            String?
  iban           String?
  bic            String?
  taxNumber      String?  @map("tax_number")
  taxOfficeName  String?  @map("tax_office_name")
  avatarPath     String?  @map("avatar_path")
  createdAt      DateTime @default(now()) @map("created_at")

  quotes Quote[]

  @@map("users")
}

model Quote {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  clientName String?  @map("client_name")
  customerAddress String? @map("customer_address")
  currency   String   @default("EUR") @map("currency")
  vatRate    Float    @default(0.19) @map("vat_rate")
  subtotal   Float    @default(0)
  vat        Float    @default(0)
  total      Float    @default(0)
  quoteNumber Int?    @map("quote_number")
  quoteDate   DateTime? @map("quote_date")
  validUntil  DateTime? @map("valid_until")
  sentAt      DateTime? @map("sent_at")
  sentByEmail Boolean   @default(false) @map("sent_by_email")
  sentByWhats Boolean   @default(false) @map("sent_by_whatsapp")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items QuoteItem[]
  attachments QuoteAttachment[]

  @@map("quotes")
}

model QuoteItem {
  id       String @id @default(uuid())
  quoteId  String @map("quote_id")
  itemName String @map("item_name")
  quantity Float  @default(1)
  price    Float
  total    Float

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model QuoteAttachment {
  id        String   @id @default(uuid())
  quoteId   String   @map("quote_id")
  filename  String
  mimeType  String   @map("mime_type")
  size      Int
  path      String
  createdAt DateTime @default(now()) @map("created_at")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_attachments")
}
